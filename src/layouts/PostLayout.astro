---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  readingMinutes: number;
}

const { title, description, pubDate, updatedDate, tags, readingMinutes } = Astro.props;

const dateStr = pubDate.toISOString().slice(0, 10);
const updatedStr = updatedDate ? updatedDate.toISOString().slice(0, 10) : null;
---

<BaseLayout title={title} description={description}>
  <article>
    <header class="post-header">
      <p class="signature">
        {dateStr} · {readingMinutes} min{updatedStr ? ` · updated ${updatedStr}` : ''} · tags: [{tags.join(', ')}]
      </p>
      <h1>{title}</h1>
    </header>
    <div class="post-content">
      <slot />
    </div>
  </article>
</BaseLayout>
